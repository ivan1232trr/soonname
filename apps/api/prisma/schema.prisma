// Prisma configuration block — specifies the query engine output format
generator client {
  // Use the default JavaScript/TypeScript client generated into node_modules
  provider = "prisma-client-js"
}

// Database connection — reads the DATABASE_URL env var set in .env
datasource db {
  // Target PostgreSQL; all migrations will be generated for Postgres dialect
  provider = "postgresql"
  // Connection string loaded from the environment; never hard-coded
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────────

// Thematic category assigned to each event by the AI classifier
// Used as a feed filter and for icon/colour coding in the UI
enum EventCategory {
  // Late-night bars, clubs, social mixers
  NIGHTLIFE
  // Competitive and recreational sporting events
  SPORTS
  // Workshops, lectures, seminars, classes
  EDUCATION
  // Restaurants, markets, culinary festivals
  FOOD
  // Fitness, meditation, health activities
  WELLNESS
  // Arts, heritage, community events
  CULTURE
  // Concerts, comedy, general entertainment
  ENTERTAINMENT
}

// Lifecycle state of an event record; only ACTIVE events appear in the public feed
enum EventStatus {
  // Newly submitted — AI classification not yet complete; hidden from public feed
  PENDING_CLASSIFICATION
  // Classified and approved — visible in city feed
  ACTIVE
  // Removed from feed for manual review due to reports or policy violation
  FLAGGED
}

// Types of interactions a user can record against an event
enum UserInteractionType {
  // User opened the event detail screen
  VIEW
  // User tapped "Interested" / saved the event
  SAVE
  // User reported the event for review
  FLAG
  // User shared the event to an external app
  SHARE
}

// Social energy preference captured during onboarding Step 2
// Used as a profile dimension that biases the AI ranking engine
enum Vibe {
  // Low-key hangouts, small gatherings, quiet spots
  CHILL
  // Parties, big events, meeting new people
  SOCIAL
  // No preference — the user is open to either
  BOTH
}

// Time-of-day preference captured during onboarding Step 3
// Stored as an array on UserProfile; each value represents one selected time window
enum TimeSlot {
  // 6am – 12pm; morning events
  MORNING
  // 12pm – 5pm; afternoon events
  AFTERNOON
  // 5pm – 10pm; evening events
  EVENING
  // 10pm onwards; late-night events
  LATE_NIGHT
}

// ── Models ─────────────────────────────────────────────────────────────────────

// Represents a CityPulse-supported city; scopes all event queries
model City {
  // UUID primary key generated by the database
  id        String   @id @default(uuid())
  // Display name shown in city picker and map headers
  name      String
  // Country the city belongs to; used for display only
  country   String
  // Decimal latitude of the city centre; used as default map viewport origin
  latitude  Float
  // Decimal longitude of the city centre; used as default map viewport origin
  longitude Float
  // IANA timezone identifier; used to render event times in the correct local time
  timezone  String
  // When this city record was first added to the database
  createdAt DateTime @default(now())

  // All events that belong to this city; cascade deletes are intentionally not set
  events    Event[]
}

// Represents a registered CityPulse user account
model User {
  // UUID primary key generated by the database
  id           String          @id @default(uuid())
  // Unique email address used for authentication; indexed for fast lookup
  email        String          @unique
  // Publicly visible display name shown on submitted events
  name         String
  // Argon2 / bcrypt hash of the user's password; raw password is never stored
  passwordHash String
  // When the user account was created
  createdAt    DateTime        @default(now())
  // When the user account was last modified (auto-managed by Prisma)
  updatedAt    DateTime        @updatedAt

  // One-to-one relationship: each user has exactly one preference profile
  profile      UserProfile?
  // Events this user has submitted; one user can submit many events
  events       Event[]
  // Interaction records (views, saves, flags) performed by this user
  interactions UserInteraction[]
}

// Extended preference and interest data attached to a user account
// Powers the AI ranking personalisation layer
model UserProfile {
  // UUID primary key generated by the database
  id              String     @id @default(uuid())
  // Foreign key linking back to the owning User; one profile per user
  userId          String     @unique
  // The city the user primarily browses; shown as the default city on app open
  preferredCityId String
  // JSON array of tag slugs reflecting the user's stated interests; min 3 required post-onboarding
  interestedTags  String[]
  // Social energy preference selected during onboarding Step 2; defaults to BOTH until set
  vibe            Vibe       @default(BOTH)
  // Time-of-day preferences selected during onboarding Step 3; empty until onboarding completes
  timePreferences TimeSlot[]
  // When the profile preferences were last saved
  updatedAt       DateTime   @updatedAt

  // Navigation property back to the User record
  user            User     @relation(fields: [userId], references: [id])
}

// A descriptive tag that can be attached to events for fine-grained filtering and ranking
model Tag {
  // UUID primary key generated by the database
  id     String  @id @default(uuid())
  // Normalised lowercase slug shown in the UI (e.g. "live-music")
  name   String  @unique

  // Many-to-many: one tag can appear on many events; managed via Prisma implicit join table
  events Event[]
}

// A CityPulse event submitted by a user or ingested from a partner source
// Includes H3 geohash indexes at three resolutions for spatial ranking
model Event {
  // UUID primary key generated by the database
  id           String        @id @default(uuid())
  // Short title displayed on feed cards and map pins
  title        String
  // Full description; may be enriched by the AI classifier pipeline
  description  String
  // Venue or area name as entered by the submitter; for display only
  locationName String
  // Decimal latitude of the event location; used to render the map pin
  latitude     Float
  // Decimal longitude of the event location; used to render the map pin
  longitude    Float

  // H3 cell at resolution 7 (~5 km² city-district granularity); used for city-level grouping
  h3R7  String @db.VarChar(15)
  // H3 cell at resolution 9 (~0.1 km² neighbourhood granularity); primary ranking dimension
  h3R9  String @db.VarChar(15)
  // H3 cell at resolution 11 (~0.001 km² venue-level precision); for precise co-location detection
  h3R11 String @db.VarChar(15)

  // AI-assigned thematic category; null until the classifier worker processes the event
  // All ACTIVE events will have a non-null category — the classifier sets it before flipping status
  category EventCategory?
  // Many-to-many: events can have multiple tags for fine-grained matching
  tags     Tag[]

  // Calendar date the event takes place; stored as a date-only timestamp
  eventDate DateTime
  // Local start time; stored as full timestamp so time zones can be applied
  startTime DateTime
  // Optional end time; null for open-ended events like exhibitions
  endTime   DateTime?

  // Lifecycle state; only ACTIVE events are shown in the public feed
  status       EventStatus @default(PENDING_CLASSIFICATION)
  // Which city this event belongs to; all feed queries are scoped to a single city
  cityId       String
  // Who submitted this event; used for attribution and moderation workflows
  submittedById String

  // When the event record was first inserted
  createdAt DateTime @default(now())
  // When the event record was last modified (auto-managed by Prisma)
  updatedAt DateTime @updatedAt

  // Navigation property to the city this event belongs to
  city        City    @relation(fields: [cityId], references: [id])
  // Navigation property to the user who submitted this event
  submittedBy User    @relation(fields: [submittedById], references: [id])
  // Interaction records referencing this event (views, saves, flags)
  interactions UserInteraction[]

  // Index on h3R7 so spatial queries grouping by city district are fast
  @@index([h3R7])
  // Index on h3R9 so proximity ranking queries (ring distance) are fast
  @@index([h3R9])
  // Index on cityId so feed queries scoped to a city avoid full table scans
  @@index([cityId])
  // Composite index so category-filtered city feed queries hit a single index
  @@index([cityId, category])
}

// Records a single user interaction with an event
// Used for personalisation signals and moderation reporting
model UserInteraction {
  // UUID primary key generated by the database
  id        String              @id @default(uuid())
  // Which user performed the interaction
  userId    String
  // Which event the interaction was performed on
  eventId   String
  // The kind of action taken (VIEW, SAVE, FLAG, SHARE)
  type      UserInteractionType
  // When the interaction was recorded; used for recency signals in ranking
  createdAt DateTime            @default(now())

  // Navigation property back to the User record
  user      User   @relation(fields: [userId], references: [id])
  // Navigation property back to the Event record
  event     Event  @relation(fields: [eventId], references: [id])

  // Index on userId so "events this user has seen" lookups are fast
  @@index([userId])
  // Index on eventId so interaction counts per event are fast to aggregate
  @@index([eventId])
}
