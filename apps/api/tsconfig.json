{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "TypeScript config for the Fastify API app; extends monorepo base and targets ESM output",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
