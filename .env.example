# AI-GENERATED
# Tool: Claude (claude-sonnet-4-6)
# Date: 2026-03-14
# Prompt summary: environment variable template for local development and CI
# Reviewed by: unreviewed

# --- API Server ---
# Port the Fastify server will bind to
API_PORT=3001
# Host address for the Fastify server; 0.0.0.0 allows connections from any interface
API_HOST=0.0.0.0

# --- Database ---
# PostgreSQL connection string; update user/password/host/dbname for your local setup
DATABASE_URL=postgresql://citypulse:password@localhost:5432/citypulse

# --- Redis ---
# Redis connection URL; used for caching and session storage
REDIS_URL=redis://localhost:6379

# --- Anthropic ---
# Secret API key for Claude AI classification features; optional, but required for automatic event classification
ANTHROPIC_API_KEY=

# --- Auth ---
# Random secret used to sign JWT tokens; generate with: openssl rand -hex 32
JWT_SECRET=

# --- App ---
# Runtime environment; controls logging verbosity and error detail exposure
NODE_ENV=development

# --- Web App ---
# Base URL the Next.js app should use when calling the Fastify API
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001/api/v1
# Google Maps JavaScript API key used by the map and event detail screens
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional Google Maps map ID required for AdvancedMarkerElement in production
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# --- S3 Spatial Index ---
# Optional bucket used to publish per-event spatial index documents partitioned by city/H3 cells
S3_BUCKET=
# Region of the bucket above
S3_REGION=
# Optional custom endpoint for S3-compatible storage such as MinIO or Cloudflare R2
S3_ENDPOINT=
# Optional static credentials; leave blank when the runtime uses IAM roles or other ambient auth
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional prefix for the generated index documents inside the bucket
S3_INDEX_PREFIX=event-index
# Set to true when using path-style S3-compatible endpoints
S3_FORCE_PATH_STYLE=false
