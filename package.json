{
  "name": "citypulse",
  "version": "0.0.1",
  "description": "CityPulse monorepo root — tooling and workspace coordination only",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @citypulse/api dev",
