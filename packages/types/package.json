{
  "name": "@citypulse/types",
  "version": "0.0.1",
  "description": "Shared TypeScript types for the Event GO monorepo",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "dev": "tsc --project tsconfig.json --watch"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
